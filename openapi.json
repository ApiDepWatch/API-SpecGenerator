{
  "openapi": "3.0.3",
  "info": {
    "title": "API",
    "version": "1.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Startup confirmation",
        "operationId": "startupConfirmation",
        "responses": {
          "200": {
            "description": "Application started message",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Application Started"
                }
              }
            }
          }
        }
      }
    },
    "/RegisterProvider": {
      "post": {
        "summary": "Register a provider service with an OpenAPI spec",
        "operationId": "registerProvider",
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "orgName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "userName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hostName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "OpenAPI specification file content",
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string"
              }
            },
            "application/json": {
              "schema": {
                "type": "string"
              }
            },
            "application/yaml": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration result message",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/RegisterConsumer": {
      "post": {
        "summary": "Register a consumer for a service",
        "operationId": "registerConsumer",
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "orgName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "userName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Registration result message",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/IsRequestValid": {
      "post": {
        "summary": "Validate a raw HTTP request against the registered OpenAPI spec for a service",
        "operationId": "isRequestValid",
        "parameters": [
          {
            "name": "projectName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Raw HTTP request string to validate",
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "\u2705 Request matches spec"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Organization": {
        "type": "object",
        "properties": {
          "orgId": {
            "type": "integer",
            "format": "int64"
          },
          "orgName": {
            "type": "string"
          }
        },
        "required": [
          "orgId",
          "orgName"
        ]
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "username": {
            "type": "string"
          },
          "restServices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RestService"
            }
          }
        },
        "required": [
          "id",
          "username"
        ]
      },
      "RestService": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "serviceName": {
            "type": "string"
          },
          "hostName": {
            "type": "string",
            "nullable": true
          },
          "specFile": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "serviceName"
        ]
      }
    }
  }
}